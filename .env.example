NODE_ENV=development
PORT=3000

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/xinra?schema=public"

JWT_SECRET="replace_with_a_long_random_secret_at_least_32_chars"
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
FRONTEND_BASE_URL="http://localhost:3001"

AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_STAFF_IMAGE_BUCKET="xinra-assets-prod"
S3_READ_URL_EXPIRES_SECONDS=600
STAFF_IMAGE_MAX_BYTES=2097152

ADMIN_NAME="Admin"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="ChangeMe123!"

# Backward-compatible seed fallback. Prefer ADMIN_* for new environments.
# SUPER_ADMIN_NAME="Super Admin"
# SUPER_ADMIN_EMAIL="superadmin@example.com"
# SUPER_ADMIN_PASSWORD="ChangeMe123!"

# Optional comma-separated list. Leave empty to allow default CORS behavior.
CORS_ORIGIN=

# Future Stripe activation placeholders for direct staff payouts.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_DEFAULT_CURRENCY=AUD
