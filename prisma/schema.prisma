generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String           @id @default(uuid())
  name                    String
  email                   String           @unique
  password                String
  stripeAccountId         String?          @map("stripe_account_id")
  profileImageKey         String?          @map("profile_image_key")
  profileImageContentType String?          @map("profile_image_content_type")
  profileImageSizeBytes   Int?             @map("profile_image_size_bytes")
  profileImageUpdatedAt   DateTime?        @map("profile_image_updated_at")
  role                    Role
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  createdVenues           Venue[]          @relation("VenueCreatedBy")
  staffVenueAssignments   StaffVenue[]     @relation("StaffVenueStaff")
  assignedStaffVenues     StaffVenue[]     @relation("StaffVenueAssignedBy")
  venueAdminAssignments   VenueAdmin[]     @relation("VenueAdminAdmin")
  assignedVenueAdmins     VenueAdmin[]     @relation("VenueAdminAssignedBy")
  tipsReceived            TipTransaction[] @relation("TipTransactionStaff")
  reviewsReceived         StaffReview[]    @relation("StaffReviewStaff")

  @@index([role])
  @@map("users")
}

model Venue {
  id                       String           @id @default(uuid())
  name                     String
  address                  String?
  email                    String?
  telephoneNumber          String?          @map("telephone_number")
  stripeAccountId          String?          @map("stripe_account_id")
  australianBusinessNumber String?          @map("australian_business_number")
  qrToken                  String           @unique @map("qr_token")
  createdById              String           @map("created_by_id")
  createdBy                User             @relation("VenueCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  staffAssignments         StaffVenue[]
  adminAssignments         VenueAdmin[]
  tipTransactions          TipTransaction[]
  staffReviews             StaffReview[]
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  @@index([createdById])
  @@map("venues")
}

model StaffVenue {
  id           String   @id @default(uuid())
  staffId      String   @map("staff_id")
  venueId      String   @map("venue_id")
  assignedById String?  @map("assigned_by_id")
  staff        User     @relation("StaffVenueStaff", fields: [staffId], references: [id], onDelete: Cascade)
  venue        Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  assignedBy   User?    @relation("StaffVenueAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@unique([staffId, venueId])
  @@index([staffId])
  @@index([venueId])
  @@index([assignedById])
  @@map("staff_venues")
}

model VenueAdmin {
  id           String   @id @default(uuid())
  venueId      String   @map("venue_id")
  adminId      String   @map("admin_id")
  assignedById String?  @map("assigned_by_id")
  venue        Venue    @relation(fields: [venueId], references: [id], onDelete: Cascade)
  admin        User     @relation("VenueAdminAdmin", fields: [adminId], references: [id], onDelete: Cascade)
  assignedBy   User?    @relation("VenueAdminAssignedBy", fields: [assignedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([venueId, adminId])
  @@index([venueId])
  @@index([adminId])
  @@index([assignedById])
  @@map("venue_admins")
}

model TipTransaction {
  id                         String       @id @default(uuid())
  venueId                    String       @map("venue_id")
  staffId                    String       @map("staff_id")
  totalAmount                Decimal      @map("total_amount") @db.Decimal(10, 2)
  platformFee                Int          @default(3) @map("platform_fee")
  platformEarnAmount         Decimal      @map("platform_earn_amount") @db.Decimal(10, 2)
  staffEarnAmount            Decimal      @map("staff_earn_amount") @db.Decimal(10, 2)
  currency                   String       @default("AUD")
  status                     TipStatus    @default(RECORDED)
  destinationStripeAccountId String?      @map("destination_stripe_account_id")
  stripePaymentIntentId      String?      @unique @map("stripe_payment_intent_id")
  venue                      Venue        @relation(fields: [venueId], references: [id], onDelete: Restrict)
  staff                      User         @relation("TipTransactionStaff", fields: [staffId], references: [id], onDelete: Restrict)
  review                     StaffReview?
  createdAt                  DateTime     @default(now())
  updatedAt                  DateTime     @updatedAt

  @@index([venueId])
  @@index([staffId])
  @@index([status])
  @@map("tip_transactions")
}

model StaffReview {
  id        String          @id @default(uuid())
  venueId   String          @map("venue_id")
  staffId   String          @map("staff_id")
  tipId     String?         @unique @map("tip_id")
  rating    Int
  comment   String?
  status    ReviewStatus    @default(ACTIVE)
  venue     Venue           @relation(fields: [venueId], references: [id], onDelete: Restrict)
  staff     User            @relation("StaffReviewStaff", fields: [staffId], references: [id], onDelete: Restrict)
  tip       TipTransaction? @relation(fields: [tipId], references: [id], onDelete: Restrict)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([venueId])
  @@index([staffId])
  @@index([status])
  @@index([rating])
  @@map("staff_reviews")
}

enum Role {
  ADMIN
  VENUE_ADMIN
  STAFF
}

enum TipStatus {
  RECORDED
  PENDING_PAYMENT
  SUCCEEDED
  FAILED
  CANCELED
}

enum ReviewStatus {
  ACTIVE
  PENDING_PAYMENT
  CANCELED
}
